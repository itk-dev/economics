<div id="scrollContainer" class="overflow-x-auto w-full"
     data-storage-key="hideCybersecurityProjects">
    <table
        class="table-auto border-separate border-spacing-0 border border-slate-600 relative"
        {{ stimulus_controller('planning-scroll') }}
    >
        <thead>
        <tr>
            <th class="text-left px-2 sticky left-0 z-10 border border-slate-600 bg-slate-100 dark:bg-slate-700 py-3">
                {{ 'cybersecurity_report.project'|trans }}
            </th>
            <th class="text-center px-3 border border-slate-600 bg-slate-100 dark:bg-slate-700 py-3">
                {{ 'cybersecurity_report.logged_hours'|trans }}
            </th>
        </tr>
        </thead>

        {% for project in data.projects %}
            <tbody
                {{ stimulus_controller('toggle-parent-child') }}
                data-toggle-id="{{ project.projectName }}"
            >
            <tr>
                <td class="text-left py-2 px-2 sticky left-0 z-10 whitespace-nowrap border border-slate-600 bg-slate-100 dark:bg-slate-900">
                    <div class="flex flex-row">
            <span class="flex-grow mr-3">
                {{ project.projectName }}
                {% if project.hasCybersecurityAgreement %}
                    <span class="text-green-500 ml-2">(CSA)</span>
                {% endif %}
            </span>

                        <button class="expand-btn mr-3 w-4"
                                type="button"
                            {{ stimulus_action('toggle-parent-child', 'toggleParent') }}
                                data-toggle-target="button">
                            <i class="fa-solid fa-maximize"></i>
                            <i class="fa-solid fa-minimize hidden"></i>
                        </button>
                    </div>
                </td>
                <td class="text-center px-3 border border-slate-600">
                    {{ project.totalSpent }}
                </td>
            </tr>

            {% for ticket in project.tickets %}
                <tr {{ stimulus_target('toggle-parent-child', 'parent') }}>
                    <td class="sticky left-0 z-10 text-left border border-slate-600 bg-slate-100 dark:bg-slate-900">
                        <div class="flex flex-row">
                            <span class="flex-grow mx-3 py-1">
                                &nbsp;&nbsp;{{ ticket.headline }}
                                <a href="{{ ticket.linkToIssue }}"
                                   target="_blank"
                                   class="link">
                                    #{{ ticket.projectTrackerId }}
                                </a>
                            </span>

                            <button class="expand-btn mr-3 w-4"
                                    type="button"
                                {{ stimulus_action('toggle-parent-child', 'toggleParent') }}
                                    data-toggle-target="button">
                                <i class="fa-solid fa-maximize"></i>
                                <i class="fa-solid fa-minimize hidden"></i>
                            </button>
                        </div>
                    </td>
                    <td class="text-center border border-slate-600 bg-slate-100 dark:bg-slate-900">
                        {{ ticket.totalSpent|number_format(2) }}
                    </td>
                </tr>

                {% for worklog in ticket.worklogs %}
                    <tr {{ stimulus_target('toggle-parent-child', 'parent') }}>
                        <td class="sticky left-0 z-10 text-left border border-slate-600 bg-slate-50 dark:bg-slate-800">
                            <div class="ml-8 py-1 text-sm">
                                {{ worklog.description ?: '—' }}
                            </div>
                        </td>
                        <td class="text-center border border-slate-600 bg-slate-50 dark:bg-slate-800 text-sm">
                            {{ worklog.hours }}
                        </td>
                    </tr>
                {% endfor %}
            {% endfor %}
            </tbody>
        {% endfor %}

        <tfoot>
        <tr>
            <td class="text-left py-2 px-2 sticky left-0 z-10 whitespace-nowrap border border-slate-600 bg-slate-100 dark:bg-slate-900">
                {{ 'hour_report.total'|trans }}
            </td>
            <td class="text-center px-3 border border-slate-600">
                {{ data.totalSpent|number_format(2) }}
            </td>
        </tr>
        </tfoot>
    </table>
</div>
